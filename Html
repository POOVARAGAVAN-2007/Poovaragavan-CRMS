// ==================== ACTIONS ====================
function viewCase(id) {
    window.currentCaseId = id;
    renderAppPage('case-detail');
}

function handleFileReport(e) {
    e.preventDefault();
    const title = document.getElementById('fr-title').value;
    const newReport = {
        reportId: 1000 + Math.floor(Math.random() * 9000),
        title: title,
        crimeType: document.getElementById('fr-type').value,
        location: document.getElementById('fr-location').value,
        status: 'PENDING',
        priority: 'MEDIUM',
        createdAt: new Date().toISOString().split('T')[0],
        description: document.getElementById('fr-desc').value
    };
    mockData.reports.unshift(newReport);
    showToast('Report filed successfully! Case #' + newReport.reportId, 'success');
    renderAppPage('citizen-dashboard');
}

function addCaseUpdate(reportId) {
    const status = document.getElementById('update-status').value;
    const notes = document.getElementById('update-notes').value;
    if (!notes) { showToast('Please enter notes', 'error'); return; }
    mockData.caseUpdates.push({
        updateId: Date.now(), reportId, status, notes,
        createdAt: new Date().toISOString().replace('T', ' ').substring(0, 16)
    });
    const report = mockData.reports.find(r => r.reportId === reportId);
    if (report) report.status = status;
    showToast('Case updated successfully!', 'success');
    renderAppPage('case-detail');
}

function handleFileSelect(e) {
    const files = Array.from(e.target.files);
    const list = document.getElementById('file-list');
    list.innerHTML = files.map(f => `
        <div class="file-item">
            <div style="display:flex; align-items:center; gap:8px;">
                <i class="fas fa-file"></i>
                <span>${f.name}</span>
            </div>
            <i class="fas fa-times remove" onclick="this.parentElement.remove()"></i>
        </div>
    `).join('');
}

function handleFileDrop(e) {
    e.preventDefault();
    e.currentTarget.classList.remove('dragover');
    const files = Array.from(e.dataTransfer.files);
    const list = document.getElementById('file-list');
    list.innerHTML += files.map(f => `
        <div class="file-item">
            <div style="display:flex; align-items:center; gap:8px;">
                <i class="fas fa-file"></i>
                <span>${f.name}</span>
            </div>
            <i class="fas fa-times remove" onclick="this.parentElement.remove()"></i>
        </div>
    `).join('');
}

function filterTable(query) {
    const rows = document.querySelectorAll('#reports-table tbody tr');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(query.toLowerCase()) ? '' : 'none';
    });
}

function filterStatus(status) {
    const rows = document.querySelectorAll('#reports-table tbody tr');
    rows.forEach(row => {
        if (!status || row.dataset.status === status) row.style.display = '';
        else row.style.display = 'none';
    });
}

