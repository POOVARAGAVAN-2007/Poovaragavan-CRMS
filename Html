// ==================== AUTH ====================
function selectRole(el) {
    document.querySelectorAll('.role-option').forEach(r => r.classList.remove('selected'));
    el.classList.add('selected');
    currentRole = el.dataset.role;
}

function togglePwd(id, icon) {
    const input = document.getElementById(id);
    if (input.type === 'password') { input.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
    else { input.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
}

function handleLogin(e) {
    e.preventDefault();
    const btn = document.getElementById('login-btn');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Signing in...';

    setTimeout(() => {
        const username = document.getElementById('login-username').value;
        mockData.currentUser = { username, role: currentRole.toUpperCase(), userId: Math.floor(Math.random()*100) };
        showToast('Login successful! Welcome, ' + username, 'success');
        btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Sign In';
        if (currentRole === 'citizen') renderAppPage('citizen-dashboard');
        else if (currentRole === 'officer') renderAppPage('officer-dashboard');
        else renderAppPage('admin-dashboard');
    }, 1000);
}

function handleRegister(e) {
    e.preventDefault();
    let valid = true;
    const username = document.getElementById('reg-username').value;
    const email = document.getElementById('reg-email').value;
    const password = document.getElementById('reg-password').value;
    const confirm = document.getElementById('reg-confirm').value;
    const phone = document.getElementById('reg-phone').value;

    document.querySelectorAll('.error-msg').forEach(e => e.classList.remove('show'));
    document.querySelectorAll('.form-control').forEach(e => e.classList.remove('error'));

    if (username.length < 3) { document.getElementById('err-username').classList.add('show'); document.getElementById('reg-username').classList.add('error'); valid = false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { document.getElementById('err-email').classList.add('show'); document.getElementById('reg-email').classList.add('error'); valid = false; }
    if (password.length < 8) { document.getElementById('err-password').classList.add('show'); document.getElementById('reg-password').classList.add('error'); valid = false; }
    if (password !== confirm) { document.getElementById('err-confirm').classList.add('show'); document.getElementById('reg-confirm').classList.add('error'); valid = false; }
    if (!/^\d{10}$/.test(phone)) { document.getElementById('err-phone').classList.add('show'); document.getElementById('reg-phone').classList.add('error'); valid = false; }

    if (!valid) return;

    showToast('Registration successful! Please login.', 'success');
    showPage('login');
}

function logout() {
    mockData.currentUser = null;
    showToast('Logged out successfully', 'info');
    showPage('landing');
}

